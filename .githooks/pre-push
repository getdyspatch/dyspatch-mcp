#!/usr/bin/env bash
set -euo pipefail

protected_ref="refs/heads/main"
zero_sha="0000000000000000000000000000000000000000"
push_to_main=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "$protected_ref" ] && [ "$local_sha" != "$zero_sha" ]; then
    push_to_main=1
  fi
done

if [ "$push_to_main" -eq 1 ]; then
  echo "pre-push: pushing to main, running pnpm test..."
  if ! pnpm test; then
    echo "pre-push: tests failed, push aborted. Use 'git push --no-verify' to bypass." >&2
    exit 1
  fi
fi
